// =====================================================================
// Giant Eagle POC - Version A: Lift-and-Shift (DEMO VERSION)
// Simplified for presentation: Core Bronze tables + Representative views
// ⚠️ Bronze = Synthetic placeholder data for POC only
// =====================================================================

Project version_a_demo {
  database_type: 'Databricks Delta Lake'
  Note: '''
    VERSION A PROBLEM:
    - Views query Bronze tables directly
    - SQL logic duplicated across 40+ views
    - Change 1 column? Update 40+ view definitions
    - Fix 1 JOIN bug? Copy-paste to 40+ views
  '''
}

// =====================================================================
// BRONZE LAYER - Core Tables (Synthetic POC Data)
// =====================================================================

TableGroup bronze_layer {
  bronze.item_master_ite_item
  bronze.item_master_ite_item_package
  bronze.dcinventory_dci_inventory
  bronze.dcinventory_dci_location
  bronze.pix_pix_pix_entry
  bronze.inventory_management_inm_adjustment_reason_code
}

Table bronze.item_master_ite_item {
  pk bigint [pk]
  item_id string [not null, note: 'Natural key']
  profile_id string [not null, note: 'D0001, D0044, D0080 = Facility codes']
  description string
  lpn_per_tier int
  tiers_per_pallet int
  unit_price decimal
  ext_gegl_dcxx_virtual_whse string
  created_timestamp timestamp
  __hevo__marked_deleted string [default: 'FALSE']

  Note: 'POC Bronze: Item master. Queried by ALL 51 views.'
}

Table bronze.item_master_ite_item_package {
  item_pk bigint [ref: > bronze.item_master_ite_item.pk]
  standard_quantity_uom_id string [note: 'UNIT or PACK']
  height decimal
  width decimal
  length decimal
  weight decimal
  volume decimal

  Note: 'Package dimensions (UNIT and PACK rows per item)'
}

Table bronze.dcinventory_dci_inventory {
  inventory_id string [pk]
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  facility_id string [note: 'D0001, D0044, D0080, etc.']
  location_id string [ref: > bronze.dcinventory_dci_location.location_id]
  on_hand decimal
  allocated decimal
  to_be_filled decimal
  is_in_transit string
  created_timestamp timestamp

  Note: 'POC Bronze: Inventory quantities by item/facility/location'
}

Table bronze.dcinventory_dci_location {
  location_id string [pk]
  facility_id string
  location_barcode string
  location_type string [note: 'PICK, RESERVE, STAGING']
  aisle string
  bay string
  level string

  Note: 'POC Bronze: Warehouse locations'
}

Table bronze.pix_pix_pix_entry {
  pix_entry_id string [pk]
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  facility_id string
  location_id string [ref: > bronze.dcinventory_dci_location.location_id]
  reason_code_id string [ref: > bronze.inventory_management_inm_adjustment_reason_code.reason_code_id]
  source_transaction_type string [note: 'ADJUSTMENT, CYCLE_COUNT, RECEIVING']
  adjustment_qty decimal
  created_timestamp timestamp

  Note: 'POC Bronze: Inventory adjustments (PIX entries)'
}

Table bronze.inventory_management_inm_adjustment_reason_code {
  reason_code_id string [pk]
  reason_code string [note: 'PIX, CYCLE_COUNT, DAMAGE']
  reason_description string
  profile_id string

  Note: 'POC Bronze: Adjustment reason codes'
}

// =====================================================================
// GOLD LAYER - CCS Views (Cross-facility, shared)
// =====================================================================

TableGroup gold_ccs_views {
  gold_version_a.ccs_iroo_v
  gold_version_a.ccs_qroo_v
  gold_version_a.ccs_item_snapshot_v
}

Table gold_version_a.ccs_iroo_v {
  profile_id string
  facility_id string
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  lpnpertier int
  unit_height decimal
  location_barcode string [ref: > bronze.dcinventory_dci_location.location_barcode]
  has_inv string

  Note: '''
    VIEW: All items with inventory across all facilities.
    Queries: item_master + item_package + dci_inventory + dci_location
    Full JOIN logic embedded in view definition.
  '''
}

Table gold_version_a.ccs_qroo_v {
  profile_id string
  facility_id string
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  on_hand_qty decimal
  location_barcode string [ref: > bronze.dcinventory_dci_location.location_barcode]

  Note: '''
    VIEW: Quick reference on-hand only.
    Queries: item_master + dci_inventory + dci_location
    Similar JOIN logic to ccs_iroo_v but different SELECT.
  '''
}

Table gold_version_a.ccs_item_snapshot_v {
  profile_id string
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  facility_id string
  snapshot_date date
  on_hand_qty decimal
  allocated_qty decimal

  Note: '''
    VIEW: Daily item snapshot aggregated.
    Queries: item_master + dci_inventory
    Different aggregation, same Bronze sources.
  '''
}

