// =====================================================================
// GOLD LAYER - GE_CS Views (Giant Eagle Custom/Shared)
// =====================================================================

TableGroup gold_ge_cs_views {
  gold_version_a.ge_cs_cycl_cnt_adjmt_dtlv
  gold_version_a.ge_cs_transaction_dtl_v
}

Table gold_version_a.ge_cs_cycl_cnt_adjmt_dtlv {
  pix_entry_id string [ref: > bronze.pix_pix_pix_entry.pix_entry_id]
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  facility_id string
  adjustment_qty decimal
  reason_code string [ref: > bronze.inventory_management_inm_adjustment_reason_code.reason_code]
  created_timestamp timestamp

  Note: '''
    VIEW: Cycle count adjustment details.
    Queries: pix_entry + item_master + adjustment_reason_code
    Different Bronze sources, same problem: direct queries with embedded JOINs.
  '''
}

Table gold_version_a.ge_cs_transaction_dtl_v {
  pix_entry_id string [ref: > bronze.pix_pix_pix_entry.pix_entry_id]
  item_id string [ref: > bronze.item_master_ite_item.item_id]
  facility_id string
  location_id string [ref: > bronze.dcinventory_dci_location.location_id]
  source_transaction_type string
  adjustment_qty decimal
  reason_code string [ref: > bronze.inventory_management_inm_adjustment_reason_code.reason_code]

  Note: '''
    VIEW: All inventory transactions.
    Queries: pix_entry + item_master + location + adjustment_reason_code
    Similar JOINs to ge_cs_cycl_cnt_adjmt_dtlv but different filter/SELECT.
  '''
}

// =====================================================================
// THE PROBLEM VISUALIZED
// =====================================================================

// Note: In this diagram you can see:
//
// 1. BRONZE LAYER (orange tables)
//    - 6 core tables that are queried by ALL views
//    - Each table has foreign key relationships
//
// 2. GOLD VIEWS (blue tables)
//    - CCS views: Query Bronze directly with full JOINs
//    - BICEPS views: Duplicate CCS logic + add business unit filter
//    - BICEPS variants: Duplicate BICEPS logic + add facility filter
//    - HBC views: Duplicate CCS/BICEPS logic + different BU filter
//    - GE_CS views: Query Bronze directly with different JOINs
//
// 3. THE MAINTENANCE NIGHTMARE:
//    - Want to rename item_master.description → item_description?
//      → Update 40+ view definitions
//    - Fix a JOIN bug in the item_master + item_package logic?
//      → Copy-paste fix to 40+ views
//    - Add a new column to item_master?
//      → Update 40+ views
//
// 4. TOTAL VIEW COUNT (not all shown in diagram):
//    - CCS: 4 views
//    - GE_CS: 4 views
//    - BICEPS: 14 views (1 base + 6 IROO variants + 1 base + 6 QROO variants)
//    - HBC: 14 views (same pattern)
//    - ASF: 14 views (same pattern)
//    - BRM: 2 views (only 1 DC, no variants)
//    - Top-level: 2 views (UNION ALL of BU views)
//    = 51 total views
//
// 5. WHY THIS HAPPENED:
//    - Lift-and-shift from Snowflake
//    - Minimal transformation to get POC working fast
//    - Business unit isolation (separate views per BU)
//    - Facility isolation (separate views per DC)
//    - No centralized dimension/fact layer
//
// This is what Version B fixes with dimensional modeling + template pattern.
// =====================================================================
